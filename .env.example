# Environment variables for SLURM scripts.
# Copy to .env and adjust paths for your cluster.
# Source before sbatch: `source .env && sbatch src/slurm/...`

REPO=/path/to/equivariant-sar-seg
DATA_DIR=/path/to/AvalCD/raw
SIF=/path/to/pytorch_container.sif
BIND_ROOT=/mmfs1  # Cluster filesystem root for apptainer --bind
